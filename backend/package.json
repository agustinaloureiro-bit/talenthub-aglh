{
  "name": "talenthub-aglh-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "tsc && node --test tests/*.test.mjs",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
